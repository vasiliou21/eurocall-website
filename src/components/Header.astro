---
import { categories } from '../data/catalog.js';
const { current } = Astro.props;
---
<header class="hdr">
  <div class="wrap hdr__in">
    <a href="/" class="brand" aria-label="Eurocall — Αρχική">
      <span class="brand__mark">E</span>
      <span class="brand__name">EUROCALL</span>
    </a>

    <nav class="nav" aria-label="Κύρια πλοήγηση">
      <div class="nav__item" id="megaItem">
        <button class="nav__mega-trigger" id="megaTrigger" aria-expanded="false">
          Προϊόντα
          <svg class="nav__chev" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4"/></svg>
        </button>
        <div class="mega" id="mega">
          <div class="mega__in">
            {categories.map((c) => (
              <a class="mega-cat" href={`/proionta/${c.slug}`}>
                <div class="mega-cat__t">{c.name}</div>
                <div class="mega-cat__d">{c.tagline}</div>
              </a>
            ))}
          </div>
        </div>
      </div>
      <a href="/proionta/anoxeidotes-kataskeves#custom" aria-current={current === 'custom' ? 'page' : undefined}>Κατασκευές</a>
      <a href="/epikoinonia" aria-current={current === 'contact' ? 'page' : undefined}>Επικοινωνία</a>
    </nav>

    <div class="hdr__cta">
      <div class="hdr__phone">
        <b>694 593 6149</b>
        <span>Άμεση εξυπηρέτηση</span>
      </div>
      <a href="/endiaferon" class="cart-btn" id="cartBtn" aria-label="Λίστα ενδιαφέροντος">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 4h2l2.4 12.3a1 1 0 0 0 1 .7h9.2a1 1 0 0 0 1-.8L21 8H6"/><circle cx="9" cy="20" r="1.4"/><circle cx="18" cy="20" r="1.4"/></svg>
        <span class="cart-btn__count" id="cartCount">0</span>
      </a>
      <button class="burger" id="burger" aria-label="Μενού" aria-expanded="false" aria-controls="mobileMenu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
<div class="mega__backdrop" id="megaBackdrop"></div>
<div class="mmenu__backdrop" id="mmenuBackdrop"></div>

<!-- MOBILE MENU -->
<div class="mmenu" id="mobileMenu" aria-hidden="true">
  <div class="mmenu__head">
    <span class="brand__name" style="font-size:1.2rem">EUROCALL</span>
    <button class="mmenu__close" id="mmenuClose" aria-label="Κλείσιμο">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>
  </div>
  <nav class="mmenu__body" aria-label="Πλοήγηση κινητού">
    <span class="mmenu__label">Κατηγορίες προϊόντων</span>
    <div class="mmenu__cats">
      {categories.map((c) => (
        <a class="mmenu__cat" href={`/proionta/${c.slug}`}>{c.name}<span aria-hidden="true">→</span></a>
      ))}
    </div>
    <span class="mmenu__label">Εταιρεία</span>
    <a class="mmenu__link" href="/proionta/anoxeidotes-kataskeves#custom">Custom Κατασκευές</a>
    <a class="mmenu__link" href="/epikoinonia">Επικοινωνία</a>
    <a class="mmenu__link" href="/endiaferon">Λίστα ενδιαφέροντος</a>
    <a class="mmenu__call" href="tel:+306945936149">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2z"/></svg>
      Καλέστε μας · 694 593 6149
    </a>
  </nav>
</div>

<script is:inline>
  (function () {
    const item = document.getElementById('megaItem');
    const trigger = document.getElementById('megaTrigger');
    const backdrop = document.getElementById('megaBackdrop');
    if (!item) return;
    let closeT;
    const open = () => { clearTimeout(closeT); item.classList.add('open'); backdrop.classList.add('on'); trigger.setAttribute('aria-expanded', 'true'); };
    const close = () => { item.classList.remove('open'); backdrop.classList.remove('on'); trigger.setAttribute('aria-expanded', 'false'); };
    item.addEventListener('mouseenter', open);
    item.addEventListener('mouseleave', () => { closeT = setTimeout(close, 200); });
    trigger.addEventListener('click', (e) => { e.preventDefault(); item.classList.contains('open') ? close() : open(); });
    backdrop.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    item.querySelectorAll('.mega a').forEach((a) => a.addEventListener('click', () => setTimeout(close, 60)));
  })();

  // ---- Mobile menu ----
  (function () {
    const burger = document.getElementById('burger');
    const menu = document.getElementById('mobileMenu');
    const closeBtn = document.getElementById('mmenuClose');
    const backdrop = document.getElementById('mmenuBackdrop');
    if (!burger || !menu) return;
    const open = () => {
      menu.classList.add('on'); burger.classList.add('on'); backdrop.classList.add('on');
      burger.setAttribute('aria-expanded', 'true'); menu.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      menu.classList.remove('on'); burger.classList.remove('on'); backdrop.classList.remove('on');
      burger.setAttribute('aria-expanded', 'false'); menu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };
    burger.addEventListener('click', () => menu.classList.contains('on') ? close() : open());
    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  })();
</script>
