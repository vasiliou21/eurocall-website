---
// Istos Engine — Catalog module: live product injection (client-side fetch).
// Διαβάζει τα διαθέσιμα προϊόντα του πελάτη από τη Supabase και τα προσθέτει
// στο grid, ταιριάζοντας 1:1 το markup της ProductCard.astro (ώστε να δουλεύει
// και το «καλάθι ενδιαφέροντος»).
//
// Props:
//   target  — CSS selector του grid όπου μπαίνουν οι κάρτες
//   mode    — 'category' (φίλτρο ανά slug) | 'used' (όλα τα μεταχειρισμένα)
//   slug    — απαιτείται σε mode 'category'
//   prepend — true: μπαίνουν ΠΡΙΝ τα στατικά (διαθέσιμο stock πρώτο)
import { ISTOS } from '../data/istos.js';
import { categories } from '../data/catalog.js';
const { target, mode = 'category', slug = '', prepend = true, hideSelector = '' } = Astro.props;
const names = Object.fromEntries(categories.map((c) => [c.slug, c.name]));
---
<script is:inline define:vars={{ ISTOS, names, target, mode, slug, prepend, hideSelector }}>
  (async function () {
    const hideEmpty = () => {
      if (!hideSelector) return;
      const h = document.querySelector(hideSelector);
      if (h) h.style.display = 'none';
    };
    try {
      let q = `${ISTOS.url}/rest/v1/catalog_items` +
        `?select=category_slug,name,spec,condition,images,sort_order,created_at` +
        `&client_id=eq.${ISTOS.clientId}&status=eq.available` +
        `&order=sort_order.asc,created_at.desc`;
      if (mode === 'category') q += `&category_slug=eq.${encodeURIComponent(slug)}`;
      if (mode === 'used') q += `&condition=eq.used`;

      const res = await fetch(q, { headers: { apikey: ISTOS.anon } });
      if (!res.ok) { hideEmpty(); return; }
      const rows = await res.json();
      if (!Array.isArray(rows) || !rows.length) { hideEmpty(); return; }

      const grid = document.querySelector(target);
      if (!grid) { hideEmpty(); return; }

      const esc = (s) => String(s ?? '').replace(/[&<>"]/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

      const frag = document.createDocumentFragment();
      for (const p of rows) {
        const cat = names[p.category_slug] || '';
        const img = (p.images && p.images[0]) || '/favicon.svg';
        const badge = p.condition === 'used'
          ? '<span class="prod__badge">Μεταχειρισμένο · Ελεγμένο</span>' : '';
        const el = document.createElement('article');
        el.className = 'prod';
        el.innerHTML =
          `<div class="prod__img">${badge}` +
            `<img src="${esc(img)}" alt="${esc(p.name)}" loading="lazy" /></div>` +
          `<div class="prod__body">` +
            `<span class="prod__cat">${esc(cat)}</span>` +
            `<h3>${esc(p.name)}</h3>` +
            `<p class="prod__spec">${esc(p.spec || '')}</p>` +
            `<button class="prod__cta" data-name="${esc(p.name)}" data-spec="${esc(p.spec || '')}"` +
            ` data-img="${esc(img)}" data-cat="${esc(cat)}">+ Προσθήκη στο ενδιαφέρον</button>` +
          `</div>`;

        // Σύνδεση με το «καλάθι» (τα στατικά δένονται στο DOMContentLoaded — τα
        // δυναμικά τα δένουμε εδώ, χειροκίνητα, μέσω window.EuroCart).
        const btn = el.querySelector('.prod__cta');
        const sync = () => {
          const on = window.EuroCart && window.EuroCart.has(p.name);
          btn.classList.toggle('added', !!on);
          btn.textContent = on ? '✓ Προστέθηκε' : '+ Προσθήκη στο ενδιαφέρον';
        };
        btn.addEventListener('click', () => {
          if (!window.EuroCart) return;
          window.EuroCart.toggle({ name: p.name, spec: p.spec || '', img, cat });
          sync();
        });
        sync();
        frag.appendChild(el);
      }

      if (prepend && grid.firstChild) grid.insertBefore(frag, grid.firstChild);
      else grid.appendChild(frag);

      // Επιτυχία: αν η ενότητα ξεκινά κρυφή (homepage), αποκάλυψέ την.
      if (hideSelector) {
        const h = document.querySelector(hideSelector);
        if (h) h.style.display = '';
      }

      // Ξανα-paint του counter μετά την προσθήκη
      window.EuroCart && window.EuroCart.paint && window.EuroCart.paint();
    } catch (_) { hideEmpty(); /* σιωπηλά: το στατικό περιεχόμενο μένει ως έχει */ }
  })();
</script>
