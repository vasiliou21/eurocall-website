---
import Base from '../../layouts/Base.astro';
import LiveProducts from '../../components/LiveProducts.astro';
import LiveCategories from '../../components/LiveCategories.astro';
import { virtualCategory } from '../../data/catalog.js';
import { ISTOS } from '../../data/istos.js';
---
<Base title="Κατηγορία προϊόντων — Eurocall" description="Εξοπλισμός επαγγελματικής κουζίνας — Eurocall Ιωάννινα." current="products">
  <script is:inline>
    (function () {
      const parts = location.pathname.replace(/\/$/, '').split('/');
      const slug = parts[parts.length - 1];
      if (slug && slug !== 'c') window.__euroCatSlug = slug;
    })();
  </script>

  <section class="page-head" id="catHead">
    <div class="wrap">
      <span class="eyebrow" id="catEyebrow" style="color:#9fc2ff">Φόρτωση…</span>
      <h1 id="catTitle">Κατηγορία</h1>
      <p id="catIntro"></p>
    </div>
  </section>

  <section class="sec sec--steelbg">
    <div class="wrap">
      <div class="prods prods--3" id="liveGrid"></div>
      <LiveProducts
        target="#liveGrid"
        mode="category"
        slug=""
        dynamicSlug={true}
        emptyMessage="Δεν υπάρχουν διαθέσιμα προϊόντα σε αυτή την κατηγορία αυτή τη στιγμή."
      />
      <p style="margin-top:28px;color:var(--txt-body);font-size:0.95rem">
        Για πλήρη διαθεσιμότητα και τιμές,
        <a href="/endiaferon" style="color:var(--flame);font-weight:600">στείλτε μας αίτημα προσφοράς</a> — απαντάμε εντός 24 ωρών.
      </p>
    </div>
  </section>

  <section class="sec sec--coal" id="customBlock" style="display:none">
    <div class="wrap custom">
      <div class="custom__img">
        <img src="/images/barstation_redirect_600x600.webp" alt="Custom ανοξείδωτη κατασκευή δικής μας παραγωγής" />
      </div>
      <div>
        <span class="eyebrow" style="color:#9fc2ff">Επί παραγγελία</span>
        <h2>Το φτιάχνουμε στα μέτρα σας</h2>
        <p>Σχεδιάζουμε και κατασκευάζουμε λάντζες, πάγκους, ερμάρια και πλήρεις γραμμές κουζίνας — προσαρμοσμένα στον χώρο σας, από inox AISI 304, δικής μας παραγωγής.</p>
        <ul>
          <li>Μέτρηση και σχεδιασμός στον χώρο σας</li>
          <li>Παράδοση και εγκατάσταση από το συνεργείο μας</li>
          <li>Από ένα ράφι μέχρι ολόκληρη γραμμή παραγωγής</li>
        </ul>
        <a href="/endiaferon" class="btn btn--flame">Συζητήστε την κατασκευή σας</a>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="sec-head"><span class="eyebrow">Συνεχίστε</span><h2>Άλλες κατηγορίες</h2></div>
      <div class="cats" id="otherCats"></div>
      <LiveCategories mode="other" target="#otherCats" excludeSlug="" limit={4} />
    </div>
  </section>
</Base>

<script is:inline define:vars={{ ISTOS, virtualCategory }}>
  (async function () {
    const slug = window.__euroCatSlug;
    if (!slug) { location.replace('/'); return; }

    const titleEl = document.getElementById('catTitle');
    const introEl = document.getElementById('catIntro');
    const eyebrowEl = document.getElementById('catEyebrow');
    const customBlock = document.getElementById('customBlock');
    const isUsed = slug === virtualCategory.slug;
    let cat = null;

    if (isUsed) {
      cat = virtualCategory;
    } else {
      const q = `${ISTOS.url}/rest/v1/catalog_categories` +
        `?select=slug,name,tagline,intro,hero` +
        `&client_id=eq.${ISTOS.clientId}&status=eq.active&slug=eq.${encodeURIComponent(slug)}`;
      const res = await fetch(q, { headers: { apikey: ISTOS.anon } });
      const rows = res.ok ? await res.json() : [];
      cat = rows[0] || null;
    }

    if (!cat) {
      titleEl.textContent = 'Η κατηγορία δεν βρέθηκε';
      introEl.textContent = 'Ίσως αφαιρέθηκε ή δεν υπάρχει πλέον.';
      eyebrowEl.textContent = '';
      return;
    }

    document.title = `${cat.name} — Eurocall · Εξοπλισμός Επαγγελματικής Κουζίνας`;
    eyebrowEl.textContent = isUsed ? 'Διαθέσιμα τώρα' : 'Κατηγορία προϊόντων';
    titleEl.textContent = cat.name;
    introEl.textContent = cat.intro || cat.tagline || '';

    if (slug === 'anoxeidotes-kataskeves' && customBlock) customBlock.style.display = '';

    const usedEmpty = 'Δεν υπάρχουν διαθέσιμα μεταχειρισμένα αυτή τη στιγμή. Επικοινωνήστε μαζί μας — η διαθεσιμότητα αλλάζει συχνά.';
    if (isUsed) {
      const loading = document.querySelector('[data-live-loading="#liveGrid"]');
      if (loading) loading.textContent = 'Φόρτωση προϊόντων…';
    }
  })();
</script>
