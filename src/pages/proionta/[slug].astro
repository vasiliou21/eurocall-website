---
import Base from '../../layouts/Base.astro';
import LiveProducts from '../../components/LiveProducts.astro';
import { categories } from '../../data/catalog.js';

export function getStaticPaths() {
  return categories.map((c) => ({ params: { slug: c.slug }, props: { category: c } }));
}

const { category } = Astro.props;
const others = categories.filter((c) => c.slug !== category.slug && !c.virtual);
const title = `${category.name} — Eurocall · Εξοπλισμός Επαγγελματικής Κουζίνας`;
const description = `${category.name}: ${category.intro} Νέος & μεταχειρισμένος εξοπλισμός, Ιωάννινα & πανελλαδικά. Ζητήστε προσφορά.`;
const isCustom = category.slug === 'anoxeidotes-kataskeves';
const isUsedCategory = category.slug === 'metaxeirismena';
---
<Base title={title} description={description} current="products">
  <section class="page-head">
    <div class="wrap">
      <span class="eyebrow" style="color:#9fc2ff">{isUsedCategory ? 'Διαθέσιμα τώρα' : 'Κατηγορία προϊόντων'}</span>
      <h1>{category.name}</h1>
      <p>{category.intro}</p>
    </div>
  </section>

  <section class="sec sec--steelbg">
    <div class="wrap">
      <div class="prods prods--3" id="liveGrid"></div>
      {isUsedCategory ? (
        <LiveProducts
          target="#liveGrid"
          mode="used"
          emptyMessage="Δεν υπάρχουν διαθέσιμα μεταχειρισμένα αυτή τη στιγμή. Επικοινωνήστε μαζί μας — η διαθεσιμότητα αλλάζει συχνά."
        />
      ) : (
        <LiveProducts target="#liveGrid" mode="category" slug={category.slug} />
      )}
      <p style="margin-top:28px;color:var(--txt-body);font-size:0.95rem">
        Για πλήρη διαθεσιμότητα και τιμές,
        <a href="/endiaferon" style="color:var(--flame);font-weight:600">στείλτε μας αίτημα προσφοράς</a> — απαντάμε εντός 24 ωρών.
      </p>
    </div>
  </section>

  {isCustom && (
    <section class="sec sec--coal" id="custom">
      <div class="wrap custom">
        <div class="custom__img">
          <img src="/images/barstation_redirect_600x600.webp" alt="Custom ανοξείδωτη κατασκευή δικής μας παραγωγής" />
        </div>
        <div>
          <span class="eyebrow" style="color:#9fc2ff">Επί παραγγελία</span>
          <h2>Το φτιάχνουμε στα μέτρα σας</h2>
          <p>Σχεδιάζουμε και κατασκευάζουμε λάντζες, πάγκους, ερμάρια και πλήρεις γραμμές κουζίνας — προσαρμοσμένα στον χώρο σας, από inox AISI 304, δικής μας παραγωγής.</p>
          <ul>
            <li>Μέτρηση και σχεδιασμός στον χώρο σας</li>
            <li>Παράδοση και εγκατάσταση από το συνεργείο μας</li>
            <li>Από ένα ράφι μέχρι ολόκληρη γραμμή παραγωγής</li>
          </ul>
          <a href="/endiaferon" class="btn btn--flame">Συζητήστε την κατασκευή σας</a>
        </div>
      </div>
    </section>
  )}

  <section class="sec">
    <div class="wrap">
      <div class="sec-head"><span class="eyebrow">Συνεχίστε</span><h2>Άλλες κατηγορίες</h2></div>
      <div class="cats">
        {others.slice(0, 4).map((c) => (
          <a href={`/proionta/${c.slug}`} class="catrow">
            <div class="catrow__img"><img src={c.hero} alt={c.name} loading="lazy" /></div>
            <div class="catrow__body">
              <div class="catrow__top"><h3>{c.name}</h3></div>
              <p class="catrow__desc">{c.intro}</p>
              <span class="catrow__link">Δείτε προϊόντα →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
